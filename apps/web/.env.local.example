# Copy this file to .env.local before starting the web dev server.
# .env.local is gitignored — it must be created manually on every new machine.
#
# NEXT_PUBLIC_* variables are baked in at compile time by Next.js.
# They cannot be injected via PM2 env or shell after the process starts —
# they MUST exist in this file (or the shell environment) before `next dev` runs.

# Enable the V3 Studio layout. Required — omitting this falls back to V2 silently.
NEXT_PUBLIC_STUDIO_V3=true

# API origin visible to the browser. Set to match your API_PORT.
NEXT_PUBLIC_API_ORIGIN=http://127.0.0.1:4000

# API origin used by Next.js server-side rendering (internal, not browser-facing).
OPENDESIGN_API_INTERNAL_URL=http://127.0.0.1:4000

# Suppress Next.js telemetry.
NEXT_TELEMETRY_DISABLED=1
