NODE_ENV=development
OPENDESIGN_PUBLIC_HOST=127.0.0.1
WEB_PORT=3000
API_PORT=4000
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
OPENDESIGN_API_INTERNAL_URL=http://127.0.0.1:4000
NEXT_PUBLIC_API_ORIGIN=http://127.0.0.1:4000

# Enable the V3 Studio layout (full-bleed canvas + floating conversation panel).
# REQUIRED — without this the old V2 layout is shown regardless of code changes.
# This must be set before Next.js starts (use apps/web/.env.local, not PM2 env).
NEXT_PUBLIC_STUDIO_V3=true

DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/opendesign
REDIS_URL=redis://127.0.0.1:6379

S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=opendesign-assets
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# External browser-facing URLs used by Better Auth callback/session flows.
BETTER_AUTH_SECRET=replace-me
BETTER_AUTH_URL=http://127.0.0.1:4000
WEB_BASE_URL=http://127.0.0.1:3000
PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=
PLAYWRIGHT_SITE_CAPTURE_DISABLED=

LITELLM_PORT=4001
LITELLM_CONFIG_PATH=./litellm-config.yaml
LITELLM_MASTER_KEY=replace-me
LITELLM_SALT_KEY=replace-me
LITELLM_API_BASE_URL=http://127.0.0.1:4001
OPENDESIGN_GENERATION_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
